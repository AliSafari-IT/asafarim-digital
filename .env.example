# ─── Database ─────────────────────────────────────────────────
POSTGRES_USER=asafarim
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=asafarim
DATABASE_URL=postgresql://asafarim:change_me_in_production@localhost:5432/asafarim

# ─── Auth.js ──────────────────────────────────────────────────
# Generate with:
#   Linux/macOS: openssl rand -base64 32
#   Windows PowerShell: Add-Type -AssemblyName System.Web; [System.Web.Security.Membership]::GeneratePassword(32,0)
AUTH_SECRET=

# Cookie domain for cross-subdomain SSO
# Production: .asafarim.com
# Development: leave empty (defaults to localhost)
AUTH_COOKIE_DOMAIN=

# ─── Google OAuth ─────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=***
AUTH_GOOGLE_SECRET=***

# ─── App URLs ─────────────────────────────────────────────────
PORTAL_URL=https://portal-qa.asafarim.com
CONTENT_GENERATOR_URL=https://content-generator-qa.asafarim.com
NEXT_PUBLIC_CONTENT_GENERATOR_URL=https://content-generator-qa.asafarim.com

# ─── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# ─── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-haiku-4-5
