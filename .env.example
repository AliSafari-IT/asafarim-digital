# ─── Database ─────────────────────────────────────────────────
POSTGRES_USER=asafarim
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=asafarim
DATABASE_URL=postgresql://asafarim:change_me_in_production@localhost:55432/asafarim

# ─── Auth.js ──────────────────────────────────────────────────
# Generate with:
#   Linux/macOS: openssl rand -base64 32
#   Windows PowerShell: Add-Type -AssemblyName System.Web; [System.Web.Security.Membership]::GeneratePassword(32,0)
AUTH_SECRET=

# Cookie domain for cross-subdomain SSO
# Production: .asafarim.com
# Development: leave empty (defaults to localhost)
AUTH_COOKIE_DOMAIN=

# ─── Google OAuth ─────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=***
AUTH_GOOGLE_SECRET=***
AUTH_GOOGLE_CALLBACK_URL=https://portal-qa.asafarim.com/api/auth/callback/google

# ─── App URLs ─────────────────────────────────────────────────
PORTAL_URL=https://portal-qa.asafarim.com
# Client-visible portal URL used by cross-app navigation buttons.
# Local dev: http://localhost:3000
NEXT_PUBLIC_PORTAL_URL=https://portal-qa.asafarim.com
CONTENT_GENERATOR_URL=https://content-generator-qa.asafarim.com
NEXT_PUBLIC_CONTENT_GENERATOR_URL=https://content-generator-qa.asafarim.com
MARKETING_CONTENT_URL=https://marketing-content.asafarim.com
NEXT_PUBLIC_MARKETING_CONTENT_URL=https://marketing-content.asafarim.com
# Local dev override for portal redirect (/showcase/marketing-content)
LOCAL_MARKETING_CONTENT_URL=http://localhost:3004

# ─── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# ─── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-haiku-4-5
