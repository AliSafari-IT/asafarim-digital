// ASafariM Digital — Prisma Schema
// Auth.js v5 required tables + full RBAC + CMS + admin panel

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js Required Models ───────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  jobTitle      String?
  company       String?
  website       String?
  location      String?
  bio           String?   @db.Text

  isActive      Boolean   @default(true)
  deactivatedAt DateTime?

  // Marketing attribution (captured at signup)
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?
  referrer    String? @db.Text
  landingPage String? @db.Text

  // Multi-tenant
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  // Auth.js relations
  accounts Account[]
  sessions Session[]

  // RBAC: many-to-many roles
  userRoles UserRole[]

  // Audit trail
  auditLogs AuditLog[]

  // Content generator
  contentFolders         ContentProjectFolder[]
  contentChatSessions    ContentChatSession[]
  savedPrompts           SavedPrompt[]
  contentGenerations     ContentGeneration[]
  contentTypeDefinitions ContentTypeDefinition[]

  // EduMatch
  eduStudentProfile  EduStudentProfile?
  eduTutorProfile    EduTutorProfile?
  eduInquiries       EduInquiry[]
  eduQuotes          EduQuote[]
  eduStudentBookings EduBooking[]       @relation("EduBookingStudent")
  eduTutorBookings   EduBooking[]       @relation("EduBookingTutor")
  eduTransactions    EduTransaction[]
  eduWallet          EduWallet?
  eduNotifications   EduNotification[]
  eduMessages        EduMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([email])
  @@index([username])
  @@index([isActive])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─── RBAC Models ───────────────────────────────────────────────

model Role {
  id          String  @id @default(cuid())
  name        String  @unique
  displayName String
  description String? @db.Text
  isSystem    Boolean @default(false)
  isDefault   Boolean @default(false)

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([isDefault])
}

model Permission {
  id          String  @id @default(cuid())
  name        String  @unique
  displayName String
  description String?
  group       String

  rolePermissions RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([group])
}

model UserRole {
  id         String   @id @default(cuid())
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  assignedBy String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

// ─── CMS Models ────────────────────────────────────────────────

model SiteContent {
  id          String  @id @default(cuid())
  section     String  @unique
  title       String?
  subtitle    String?
  eyebrow     String?
  body        Json?
  metadata    Json?
  position    Int     @default(0)
  isPublished Boolean @default(true)
  updatedBy   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([section])
  @@index([position])
  @@index([isPublished])
}

model NavItem {
  id           String  @id @default(cuid())
  label        String
  href         String
  position     Int     @default(0)
  visibility   String  @default("public")
  requiredRole String?
  parentId     String?
  isActive     Boolean @default(true)
  icon         String?
  target       String? @default("_self")
  group        String  @default("main")

  parent   NavItem?  @relation("NavItemTree", fields: [parentId], references: [id])
  children NavItem[] @relation("NavItemTree")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([group])
  @@index([position])
  @@index([visibility])
  @@index([parentId])
}

model SiteSetting {
  id          String  @id @default(cuid())
  key         String  @unique
  value       Json
  group       String  @default("general")
  displayName String?
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
  @@index([group])
}

// ─── Audit Log ─────────────────────────────────────────────────

model AuditLog {
  id        String  @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  changes   Json?
  ipAddress String?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([action])
  @@index([createdAt])
}

// ─── Multi-Tenant Models ───────────────────────────────────────

model Tenant {
  id               String    @id @default(cuid())
  name             String
  slug             String    @unique
  plan             String    @default("free")
  status           String    @default("active") // active, trial, past_due, churned, suspended
  mrrCents         Int       @default(0)
  seats            Int       @default(1)
  region           String    @default("EU")
  industry         String?
  primaryContactId String?
  trialEndsAt      DateTime?
  churnedAt        DateTime?

  users            User[]
  subscriptions    Subscription[]
  featureOverrides FeatureFlagOverride[]
  lifecycleEvents  LifecycleEvent[]
  usageMetrics     UsageMetric[]

  // Content generator
  contentFolders         ContentProjectFolder[]
  contentChatSessions    ContentChatSession[]
  savedPrompts           SavedPrompt[]
  contentGenerations     ContentGeneration[]
  contentTypeDefinitions ContentTypeDefinition[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([status])
  @@index([plan])
}

// ─── SaaS Operations Hub ───────────────────────────────────────

model Plan {
  id         String  @id @default(cuid())
  code       String  @unique // free, starter, pro, enterprise
  name       String
  priceCents Int     @default(0)
  currency   String  @default("USD")
  interval   String  @default("month") // month, year
  seatLimit  Int?
  features   Json? // array of feature flag codes included
  isActive   Boolean @default(true)
  sortOrder  Int     @default(0)

  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
}

model Subscription {
  id          String    @id @default(cuid())
  tenantId    String
  planId      String
  status      String    @default("active") // active, trialing, past_due, canceled, paused
  startedAt   DateTime  @default(now())
  renewsAt    DateTime?
  canceledAt  DateTime?
  trialEndsAt DateTime?
  seats       Int       @default(1)
  mrrCents    Int       @default(0)
  externalId  String? // e.g. Stripe subscription id

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan     Plan      @relation(fields: [planId], references: [id])
  invoices Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([planId])
}

model Invoice {
  id             String    @id @default(cuid())
  subscriptionId String
  number         String    @unique
  amountCents    Int
  currency       String    @default("USD")
  status         String    @default("paid") // paid, open, void, uncollectible, failed
  issuedAt       DateTime  @default(now())
  paidAt         DateTime?

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([subscriptionId])
  @@index([status])
  @@index([issuedAt])
}

model FeatureFlag {
  id             String  @id @default(cuid())
  code           String  @unique // e.g. "advanced_analytics"
  name           String
  description    String? @db.Text
  category       String  @default("general") // general, beta, experimental, killswitch
  defaultEnabled Boolean @default(false)
  rolloutPercent Int     @default(0) // 0-100

  overrides FeatureFlagOverride[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model FeatureFlagOverride {
  id       String  @id @default(cuid())
  flagId   String
  tenantId String
  enabled  Boolean
  note     String?

  flag   FeatureFlag @relation(fields: [flagId], references: [id], onDelete: Cascade)
  tenant Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([flagId, tenantId])
  @@index([tenantId])
}

model LifecycleEvent {
  id         String   @id @default(cuid())
  tenantId   String
  kind       String // signup, activated, upgraded, downgraded, churn_risk, churned, recovered, expansion, support_ticket
  title      String
  details    String?  @db.Text
  severity   String   @default("info") // info, success, warning, danger
  occurredAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([kind])
  @@index([occurredAt])
}

model UsageMetric {
  id          String   @id @default(cuid())
  tenantId    String
  metric      String // api_calls, active_users, storage_mb, seats_used
  value       Int
  periodStart DateTime

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, metric, periodStart])
  @@index([metric])
  @@index([periodStart])
}

model Automation {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  description String?   @db.Text
  trigger     String // schedule, event
  schedule    String? // cron expression
  eventType   String? // e.g. "tenant.churn_risk"
  action      String // notify, tag, email, run_webhook
  config      Json?
  isEnabled   Boolean   @default(true)
  lastRunAt   DateTime?
  lastStatus  String?

  runs AutomationRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([trigger])
  @@index([isEnabled])
}

model AutomationRun {
  id           String    @id @default(cuid())
  automationId String
  status       String // success, failed, skipped
  output       String?   @db.Text
  startedAt    DateTime  @default(now())
  completedAt  DateTime?

  automation Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId])
  @@index([status])
  @@index([startedAt])
}

// ─── App Registry & System Health ──────────────────────────────

model AppRegistry {
  id             String    @id @default(cuid())
  code           String    @unique // portal, content-generator, ops-hub, marketing-content
  name           String
  description    String?   @db.Text
  url            String // public URL (prod/qa subdomain)
  healthUrl      String // /api/health endpoint
  environment    String    @default("qa") // dev, qa, prod
  isEnabled      Boolean   @default(true)
  lastDeployedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  healthChecks HealthCheck[]

  @@index([environment])
  @@index([isEnabled])
}

model HealthCheck {
  id             String   @id @default(cuid())
  appId          String
  status         String // ok, degraded, down
  httpStatus     Int?
  responseTimeMs Int?
  error          String?  @db.Text
  checkedAt      DateTime @default(now())

  app AppRegistry @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([appId])
  @@index([checkedAt])
  @@index([status])
}

// ─── Content Generator: Project / Chat / Prompt Persistence ────

model ContentProjectFolder {
  id          String  @id @default(cuid())
  userId      String
  tenantId    String?
  parentId    String?
  name        String
  description String? @db.Text
  color       String?
  icon        String?
  position    Int     @default(0)
  isArchived  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant   Tenant?                @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  parent   ContentProjectFolder?  @relation("ContentProjectFolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children ContentProjectFolder[] @relation("ContentProjectFolderTree")

  chatSessions ContentChatSession[]
  savedPrompts SavedPrompt[]
  generations  ContentGeneration[]

  @@index([userId])
  @@index([tenantId])
  @@index([parentId])
  @@index([isArchived])
}

model ContentChatSession {
  id            String    @id @default(cuid())
  userId        String
  tenantId      String?
  folderId      String?
  title         String
  contentType   String?
  status        String    @default("active")
  lastMessageAt DateTime?
  metadata      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant?               @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  folder ContentProjectFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  messages     ContentChatMessage[]
  savedPrompts SavedPrompt[]
  generations  ContentGeneration[]

  @@index([userId])
  @@index([tenantId])
  @@index([folderId])
  @@index([status])
  @@index([updatedAt])
}

model ContentChatMessage {
  id          String  @id @default(cuid())
  sessionId   String
  role        String // system, user, assistant
  content     String  @db.Text
  contentType String?
  provider    String?
  model       String?
  metadata    Json?

  createdAt DateTime @default(now())

  session ContentChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model SavedPrompt {
  id           String   @id @default(cuid())
  userId       String
  tenantId     String?
  folderId     String?
  sessionId    String?
  title        String
  contentType  String
  prompt       String   @db.Text
  systemPrompt String?  @db.Text
  tags         String[]
  isFavorite   Boolean  @default(false)
  metadata     Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant  Tenant?               @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  folder  ContentProjectFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  session ContentChatSession?   @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([tenantId])
  @@index([folderId])
  @@index([sessionId])
  @@index([isFavorite])
}

model ContentTypeDefinition {
  id                 String   @id @default(cuid())
  slug               String
  label              String
  description        String?  @db.Text
  promptInstructions String?  @db.Text
  systemPrompt       String?  @db.Text
  isSystem           Boolean  @default(false)
  isActive           Boolean  @default(true)
  userId             String?
  tenantId           String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, slug])
  @@unique([tenantId, slug])
  @@index([slug])
  @@index([userId])
  @@index([tenantId])
  @@index([isSystem])
  @@index([isActive])
}

model ContentGeneration {
  id               String  @id @default(cuid())
  userId           String
  tenantId         String?
  folderId         String?
  sessionId        String?
  contentType      String
  prompt           String  @db.Text
  output           String? @db.Text
  provider         String?
  model            String?
  status           String // succeeded, failed
  error            String? @db.Text
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  metadata         Json?

  createdAt DateTime @default(now())

  user    User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant  Tenant?               @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  folder  ContentProjectFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  session ContentChatSession?   @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([tenantId])
  @@index([folderId])
  @@index([sessionId])
  @@index([status])
  @@index([createdAt])
}

// ─── EduMatch Models ───────────────────────────────────────────
// AI-first homework help + tutor marketplace.
// See docs/edumatch-project-plan.md.
//
// Identity reuses the global `User` model. STUDENT vs TUTOR is implicit
// by the presence of EduStudentProfile / EduTutorProfile (a user may be
// both). ADMIN flows through the existing RBAC system.
//
// Geo fields use PostGIS via `Unsupported("geography(Point, 4326)")`.
// Spatial queries (e.g. ST_DWithin) must use `$queryRaw`. The first
// migration must `CREATE EXTENSION IF NOT EXISTS postgis;`.

model EduStudentProfile {
  id                 String                                 @id @default(cuid())
  userId             String                                 @unique
  gradeLevel         String // K12, UNDERGRAD, GRAD
  subjectsOfInterest String[]                               @default([])
  homeAddress        Json?
  homeLocation       Unsupported("geography(Point, 4326)")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([gradeLevel])
}

model EduTutorProfile {
  id              String                                 @id @default(cuid())
  userId          String                                 @unique
  bio             String?                                @db.Text
  subjectsTaught  String[]                               @default([])
  levelsTaught    String[]                               @default([])
  hourlyRateCents Int                                    @default(0)
  onlineOnly      Boolean                                @default(false)
  serviceRadiusKm Int                                    @default(10)
  homeAddress     Json?
  homeLocation    Unsupported("geography(Point, 4326)")?

  // Stripe Connect (Phase 4)
  stripeAccountId String? @unique
  payoutEnabled   Boolean @default(false)

  // Trust & quality
  verifiedAt  DateTime?
  ratingAvg   Float     @default(0)
  ratingCount Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([onlineOnly])
  @@index([hourlyRateCents])
  @@index([ratingAvg])
  @@index([verifiedAt])
}

model EduInquiry {
  id          String  @id @default(cuid())
  studentId   String
  subject     String
  gradeLevel  String
  description String  @db.Text
  attachments Json? // [{ type, url, mime, sizeBytes }]
  aiSummary   String? @db.Text
  status      String  @default("NEW") // NEW, AI_RESPONDED, TUTOR_REQUESTED, BOOKED, CLOSED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student       User              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  aiResponses   EduAiResponse[]
  quoteRequests EduQuoteRequest[]

  @@index([studentId])
  @@index([status])
  @@index([subject])
  @@index([createdAt])
}

model EduAiResponse {
  id               String  @id @default(cuid())
  inquiryId        String
  modelUsed        String
  promptVersion    String
  explanation      String  @db.Text
  studyPlan        Json?
  practiceProblems Json?
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  tokenCostMicros  Int? // 1/1,000,000 of a USD, integer math for billing
  latencyMs        Int?
  truncated        Boolean @default(false)
  stopReason       String?

  createdAt DateTime @default(now())

  inquiry EduInquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@index([inquiryId])
  @@index([createdAt])
}

model EduQuoteRequest {
  id          String   @id @default(cuid())
  inquiryId   String
  studentId   String
  requestedAt DateTime @default(now())
  expiresAt   DateTime
  status      String   @default("OPEN") // OPEN, FULFILLED, EXPIRED, CANCELLED

  inquiry EduInquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  quotes  EduQuote[]

  @@index([inquiryId])
  @@index([studentId])
  @@index([status])
  @@index([expiresAt])
}

model EduQuote {
  id                String  @id @default(cuid())
  quoteRequestId    String
  tutorId           String
  hourlyRateCents   Int
  estimatedHours    Float
  totalCents        Int
  availabilitySlots Json? // [{ start, end, mode }]
  notes             String? @db.Text
  pdfUrl            String?
  status            String  @default("PENDING") // PENDING, SENT, ACCEPTED, DECLINED, EXPIRED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quoteRequest EduQuoteRequest @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  tutor        User            @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  booking      EduBooking?

  @@unique([quoteRequestId, tutorId])
  @@index([quoteRequestId])
  @@index([tutorId])
  @@index([status])
}

model EduBooking {
  id                    String    @id @default(cuid())
  quoteId               String    @unique
  studentId             String
  tutorId               String
  scheduledAt           DateTime
  durationMinutes       Int
  mode                  String // ONLINE, IN_PERSON
  meetingUrl            String?
  stripePaymentIntentId String?   @unique
  status                String    @default("SCHEDULED") // SCHEDULED, COMPLETED, CANCELLED, DISPUTED
  completedAt           DateTime?
  cancelledAt           DateTime?
  cancellationReason    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quote        EduQuote         @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  student      User             @relation("EduBookingStudent", fields: [studentId], references: [id], onDelete: Cascade)
  tutor        User             @relation("EduBookingTutor", fields: [tutorId], references: [id], onDelete: Cascade)
  transactions EduTransaction[]
  messages     EduMessage[]

  @@index([studentId])
  @@index([tutorId])
  @@index([status])
  @@index([scheduledAt])
}

model EduTransaction {
  id               String  @id @default(cuid())
  bookingId        String
  tutorId          String
  type             String // CHARGE, REFUND, PAYOUT, PLATFORM_FEE
  grossCents       Int
  platformFeeCents Int     @default(0)
  netCents         Int
  currency         String  @default("EUR")
  stripeChargeId   String?
  stripePayoutId   String?

  createdAt DateTime @default(now())

  booking EduBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  tutor   User       @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([tutorId])
  @@index([type])
  @@index([createdAt])
  @@index([stripeChargeId])
}

model EduWallet {
  tutorId              String    @id
  balanceCents         Int       @default(0)
  pendingCents         Int       @default(0)
  payoutThresholdCents Int       @default(5000)
  currency             String    @default("EUR")
  lastPayoutAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tutor User @relation(fields: [tutorId], references: [id], onDelete: Cascade)
}

model EduNotification {
  id      String    @id @default(cuid())
  userId  String
  type    String // INQUIRY_RECEIVED, AI_RESPONSE_READY, QUOTE_RECEIVED, BOOKING_CONFIRMED, PAYOUT_SENT, ...
  payload Json?
  readAt  DateTime?
  sentAt  DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([readAt])
  @@index([createdAt])
}

model EduMessage {
  id        String @id @default(cuid())
  bookingId String
  senderId  String
  body      String @db.Text

  createdAt DateTime @default(now())

  booking EduBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  sender  User       @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([senderId])
  @@index([createdAt])
}
