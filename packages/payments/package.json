{
  "name": "@asafarim/payments",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cart": {
      "import": "./dist/cart-service.mjs",
      "require": "./dist/cart-service.js",
      "types": "./dist/cart-service.d.ts"
    },
    "./checkout": {
      "import": "./dist/checkout.mjs",
      "require": "./dist/checkout.js",
      "types": "./dist/checkout.d.ts"
    },
    "./webhooks": {
      "import": "./dist/webhooks.mjs",
      "require": "./dist/webhooks.js",
      "types": "./dist/webhooks.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/cart-service.ts src/checkout.ts src/webhooks.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts src/cart-service.ts src/checkout.ts src/webhooks.ts --format esm,cjs --dts --watch",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@asafarim/db": "workspace:*",
    "stripe": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "tsup": "^8.3.0"
  }
}
