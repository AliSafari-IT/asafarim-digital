# EduMatch — environment template
# Copy to .env and fill in real values. Never commit .env.

# Public base URL (used by client-side links, og tags, callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3005

# Optional sub-path mount (leave empty for root)
NEXT_PUBLIC_BASE_PATH=

# Centralized auth (Phase 1.2). Reuses the portal-managed NextAuth session.
# AUTH_SECRET *must* match the value in apps/portal/.env so cross-app sessions
# decode correctly. Generate once with:
#   openssl rand -base64 32
AUTH_SECRET=
PORTAL_URL=http://localhost:3000

# Cookie domain for cross-subdomain SSO. Leave blank for localhost; set to
# `.asafarim.com` in production so portal & edumatch share the session cookie.
AUTH_COOKIE_DOMAIN=

# Database (Phase 1.1). Reuses packages/db Prisma client.
# DATABASE_URL=postgresql://user:pass@localhost:5432/asafarim

# AI providers (Phase 2.2)
# OpenAI is primary; supports vision (gpt-4o) and chat (gpt-4o-mini).
# Whisper-1 is used automatically for audio transcription.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL_VISION=gpt-4o
# OPENAI_MODEL_CHAT=gpt-4o-mini
# OPENAI_MAX_TOKENS=4000

# Anthropic is failover when OpenAI fails or is unavailable.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# ANTHROPIC_MAX_TOKENS=4000

# Redis / BullMQ job queue (Phase 2.2). Required for async AI processing.
# Use rediss:// for TLS (Upstash, ElastiCache). Not required for local streaming.
# REDIS_URL=redis://localhost:6379

# Object storage (Phase 2.1) — DigitalOcean Spaces / S3-compatible
# SPACES_ENDPOINT=
# SPACES_REGION=
# SPACES_BUCKET=
# SPACES_ACCESS_KEY=
# SPACES_SECRET_KEY=

# Stripe Connect (Phase 4)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_CONNECT_CLIENT_ID=

# Google Maps (Phase 1.3 / 3.1)
# GOOGLE_MAPS_API_KEY=

# PDF Generation (Phase 5.1)
# DigitalOcean Spaces config (also used for uploads)
DO_SPACES_ENDPOINT=
DO_SPACES_REGION=
DO_SPACES_BUCKET=
DO_SPACES_ACCESS_KEY=
DO_SPACES_SECRET_KEY=

# Email Notifications (Phase 5.2)
# Get API key from https://resend.com
RESEND_API_KEY=
FROM_EMAIL=EduMatch <noreply@asafarim.com>
